{
  "name": "agent-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": "tsx src/server/index.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "tsx src/data/migrate.ts",
    "db:seed": "tsx src/data/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headless": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc --noEmit --project tsconfig.server.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/node-server": "^2.0.3",
    "dotenv": "^17.4.2",
    "hono": "^4.12.21",
    "next": "^15.3.1",
    "pg": "^8.13.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "uuid": "^11.1.0",
    "ws": "^8.20.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
